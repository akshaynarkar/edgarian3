# Application
APP_NAME=Edgarian
APP_ENV=development
DEV_MODE=true
LOG_LEVEL=INFO
SECRET_KEY=dev-insecure-key
TZ=UTC

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# SEC / data providers
SEC_USER_AGENT=your@email.com
REQUEST_TIMEOUT_SECONDS=30

# PostgreSQL (docker compose)
POSTGRES_DB=edgarian
POSTGRES_USER=edgarian
POSTGRES_PASSWORD=edgarian
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
DATABASE_URL=postgresql+psycopg://edgarian:edgarian@localhost:5433/edgarian

# pgAdmin
PGADMIN_DEFAULT_EMAIL=admin@edgarian.local
PGADMIN_DEFAULT_PASSWORD=admin
PGADMIN_PORT=5050

# Phase 3 placeholders kept here for a single env source of truth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
